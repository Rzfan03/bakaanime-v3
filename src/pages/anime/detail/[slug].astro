---
export const prerender = false;
import Layout from "../../../layouts/Layout.astro";
const { slug } = Astro.params
const ApiUrl = await fetch(`https://www.sankavollerei.com/anime/anime/${slug}`)
const Result = await ApiUrl.json()
const EpsList = Result.data.episodeList
const Anime = Result.data
const Genre = Anime.genreList
const AnimeSynop = Anime.synopsis
const RecommendedAnime = Anime.recommendedAnimeList
---

<Layout>
    <section class="min-h-screen bg-zinc-900 p-8 flex flex-col items-center overflow-auto">
        <div class="max-w-6xl w-full flex flex-col gap-12">
            
            <div class="flex max-md:flex-col justify-between gap-12">
                <div class="flex-shrink-0">
                    <img class="w-90" src={Anime.poster}/>
                </div>
                <div class="flex flex-col gap-3">
                    <h1 class="text-zinc-200 text-4xl max-w-xl font-medium">{Anime.title}</h1>
                    <h1 class="text-zinc-200 text-4xl max-w-xl font-medium">{Anime.japanese}</h1>
                    <div class="flex gap-3">
                        <p class="text-zinc-200 max-md:text-sm p-2 bg-zinc-800 border border-zinc-700">Status : {Anime.status}</p>
                        <p class="text-zinc-200 max-md:text-sm p-2 bg-zinc-800 border border-zinc-700">Type : {Anime.type}</p>
                        <p class="text-zinc-200 max-md:text-sm p-2 bg-zinc-800 border border-zinc-700">Episode : {Anime.episodes || "Not Found"}</p>
                    </div>
                    <div class="flex gap-3">
                        {Genre.map((data:any) => (
                            <p class="text-zinc-200 underline text-sm">{data.title}</p>
                        ))}
                    </div>
                    <div class="text-sm text-zinc-400 max-w-md">
                        {Array.isArray(AnimeSynop.paragraphs) ? AnimeSynop.paragraphs.map((p:string) => (
                            <p class="mb-2">{p}</p>
                        )) : <p>{AnimeSynop.paragraphs || "Anime ini tidak punya synopsis"}</p>}
                    </div>
                </div>
            </div>

            <div class="bg-zinc-900 border border-zinc-800 w-full">
                <h1 class="bg-zinc-800 p-2 text-white">Episode List</h1>
                <div class="grid grid-cols-3 md:grid-cols-5 gap-3 p-3">
                    {EpsList.map((data:any) => (
                    <a href={`/anime/episode/${data.episodeId}`}>
                        <div class="p-2 text-center bg-zinc-700 border border-zinc-600 hover:bg-zinc-800 hover:border-zinc-700 transition-all text-zinc-200">
                            <p class="font-medium text-sm">{data.eps}</p>
                        </div>
                    </a>
                    ))}
                </div>
            </div>

            <div class="bg-zinc-900 border w-full h-fit border-zinc-800">
                <h1 class="bg-zinc-800 p-2 text-white">Rekomendasi Anime</h1>
                <div class="grid grid-cols-5 max-md:grid-cols-2 gap-3 p-3">
                    {RecommendedAnime.map((data:any) => (
                    <a href={`/anime/detail/${data.animeId}`}>
                        <div class="p-2 flex flex-col gap-3 bg-zinc-700 border border-zinc-600 hover:bg-zinc-800 hover:border-zinc-700 transition-all text-zinc-200">
                            <img class="w-full object-cover" src={data.poster}/>
                            <p class="font-medium text-sm line-clamp-2">{data.title}</p>
                        </div>
                    </a>
                    ))}
                </div>
            </div>

        </div>
    </section>
</Layout>
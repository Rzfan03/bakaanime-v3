---
import Layout from "../../../layouts/Layout.astro";

const response = await fetch("https://www.sankavollerei.com/anime/schedule");
const result = await response.json();
const jadwal = result.data;
---

<Layout title="Jadwal Anime">
    <div class="min-h-screen p-8 flex justify-center bg-zinc-900">
        <div class="w-full max-w-7xl">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                {jadwal.map((day: any) => (
                    <div
                        key={day.day}
                        class="flex flex-col gap-3 p-4 border border-zinc-800 h-fit"
                    >
                        <h1 class="text-zinc-100 font-medium text-lg bg-zinc-800 p-2 text-center">
                            {day.day}
                        </h1>

                        <div class="grid grid-cols-4 max-md:grid-cols-3 gap-4 pt-2">
                            {day.anime_list.map((anime: any) => (
                                <div
                                    key={anime.slug}
                                    class="flex flex-col gap-2 items-center"
                                >
                                    <img
                                        src={anime.poster}
                                        alt={anime.title}
                                        class="w-12"
                                    />
                                    <a
                                        href={`../../anime/detail/${anime.slug}`}
                                        class="text-zinc-200 cursor-pointer hover:underline text-sm text-center leading-tight line-clamp-2"
                                    >
                                        {anime.title}
                                    </a>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</Layout>